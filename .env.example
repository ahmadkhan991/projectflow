# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Auth ─────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-key

# ─── Database ─────────────────────────────────
# SQLite file path — Railway mounts a volume at /data
DB_PATH=/data/projectflow.db

# ─── CORS ─────────────────────────────────────
# Set to your Railway frontend URL after deployment
# FRONTEND_URL=https://your-app.up.railway.app
